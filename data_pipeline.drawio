                <mxCell id="lc2b" value="" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="295" y="889" width="16" height="16" as="geometry"/></mxCell>
                <mxCell id="lt2" value="Preprocessing &amp; Augmentation (Steps 3–4)" style="text;html=1;fontSize=10;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="315" y="887" width="245" height="20" as="geometry"/></mxCell>
                <mxCell id="lc3b" value="" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="575" y="889" width="16" height="16" as="geometry"/></mxCell>
                <mxCell id="lt3" value="Analysis &amp; Feature Engineering (Steps 5–6)" style="text;html=1;fontSize=10;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="595" y="887" width="245" height="20" as="geometry"/></mxCell>
                <mxCell id="lc4b" value="" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="855" y="889" width="16" height="16" as="geometry"/></mxCell>
                <mxCell id="lt4" value="Model Selection &amp; Training (Steps 7–8)" style="text;html=1;fontSize=10;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="875" y="887" width="230" height="20" as="geometry"/></mxCell>
                <mxCell id="lc5b" value="" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="1115" y="889" width="16" height="16" as="geometry"/></mxCell>
