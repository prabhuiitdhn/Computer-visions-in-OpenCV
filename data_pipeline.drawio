<mxfile host="app.diagrams.net" modified="2026-05-25" agent="GitHub Copilot" version="21.0.0">
    <diagram id="ml-pipeline-roles" name="ML Pipeline by Role — Swimlane">
        <mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>

                <!-- ════════════════════════════════════════════════════ -->
                <!-- TITLE                                                 -->
                <!-- ════════════════════════════════════════════════════ -->
                <mxCell id="title" value="&lt;b&gt;&lt;font style=&quot;font-size:18px;&quot;&gt;Full Machine Learning Pipeline&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:11px;&quot; color=&quot;#555555&quot;&gt;Data Acquisition → Model Deployment  ·  Roles: Data Engineer | Data Analyst | Data Scientist | ML Engineer&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;" vertex="1" parent="1">
                    <mxGeometry x="20" y="12" width="1860" height="55" as="geometry"/>
                </mxCell>

                <!-- ════════════════════════════════════════════════════ -->
                <!-- ROW 1 — DATA ENGINEER  (Steps 1–4)                   -->
                <!-- ════════════════════════════════════════════════════ -->
                <mxCell id="de_bg" value="" style="rounded=1;arcSize=3;fillColor=#FFF3E0;strokeColor=#E65100;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="20" y="85" width="1860" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="de_hdr" value="&lt;b&gt;&lt;font style=&quot;font-size:14px;&quot;&gt;Data&lt;br&gt;Engineer&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Steps 1–4&lt;/font&gt;" style="rounded=1;arcSize=3;fillColor=#E65100;strokeColor=#BF360C;strokeWidth=2;fontColor=#FFFFFF;verticalAlign=middle;align=center;html=1;" vertex="1" parent="1">
                    <mxGeometry x="20" y="85" width="155" height="175" as="geometry"/>
                </mxCell>

                <mxCell id="s1" value="&lt;b&gt;1. Data Acquisition&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Sensors / cameras / APIs&lt;br&gt;• Web scraping / crawling&lt;br&gt;• Public datasets (ImageNet, COCO)&lt;br&gt;• Internal / proprietary data&lt;br&gt;• Simulated / synthetic data&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="195" y="107" width="320" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s2" value="&lt;b&gt;2. Data Annotation / Labelling&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Manual labelling (LabelImg, CVAT)&lt;br&gt;• Crowdsourcing (Mech. Turk)&lt;br&gt;• Weak / semi-automatic labelling&lt;br&gt;• Annotation schema definition&lt;br&gt;• Quality review &amp; IAA check&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="535" y="107" width="320" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s3" value="&lt;b&gt;3. Data Preprocessing&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Resize / normalize / standardize&lt;br&gt;• Denoise, histogram equalization&lt;br&gt;• Handle missing values / outliers&lt;br&gt;• Format conversion (→ TFRecord)&lt;br&gt;• Train / Val / Test split&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="875" y="107" width="320" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s4" value="&lt;b&gt;4. Data Augmentation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Flip, rotate, crop, scale&lt;br&gt;• Colour jitter, brightness, contrast&lt;br&gt;• MixUp, CutOut, CutMix&lt;br&gt;• Mosaic (YOLOv4+)&lt;br&gt;• Generative augmentation (GAN/Diff)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="1215" y="107" width="320" height="130" as="geometry"/>
                </mxCell>

                <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="s1" target="s2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="e23" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;strokeWidth=2;" edge="1" source="s2" target="s3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="e34" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;strokeWidth=2;" edge="1" source="s3" target="s4" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

                <!-- ════════════════════════════════════════════════════ -->
                <!-- ROW 2 — DATA ANALYST  (Steps 5–6)                    -->
                <!-- ════════════════════════════════════════════════════ -->
                <mxCell id="da_bg" value="" style="rounded=1;arcSize=3;fillColor=#F1F8E9;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="20" y="278" width="1860" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="da_hdr" value="&lt;b&gt;&lt;font style=&quot;font-size:14px;&quot;&gt;Data&lt;br&gt;Analyst&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Steps 5–6&lt;/font&gt;" style="rounded=1;arcSize=3;fillColor=#2E7D32;strokeColor=#1B5E20;strokeWidth=2;fontColor=#FFFFFF;verticalAlign=middle;align=center;html=1;" vertex="1" parent="1">
                    <mxGeometry x="20" y="278" width="155" height="175" as="geometry"/>
                </mxCell>

                <mxCell id="s5" value="&lt;b&gt;5. Exploratory Data Analysis (EDA)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Class distribution / imbalance check&lt;br&gt;• Feature correlation analysis&lt;br&gt;• Visualise samples per class&lt;br&gt;• Identify data quality issues&lt;br&gt;• Baseline statistics (mean, std, range)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="195" y="300" width="320" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s6" value="&lt;b&gt;6. Feature Engineering&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Hand-crafted features: HOG, SIFT, LBP&lt;br&gt;• Deep features: CNN embeddings&lt;br&gt;• Dimensionality reduction: PCA, t-SNE&lt;br&gt;• Feature selection (importance scores)&lt;br&gt;• Embedding lookup (text / categories)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="535" y="300" width="320" height="130" as="geometry"/>
                </mxCell>

                <mxCell id="e56" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;strokeWidth=2;" edge="1" source="s5" target="s6" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

                <!-- ════════════════════════════════════════════════════ -->
                <!-- ROW 3 — DATA SCIENTIST  (Steps 7–10)                 -->
                <!-- ════════════════════════════════════════════════════ -->
                <mxCell id="ds_bg" value="" style="rounded=1;arcSize=3;fillColor=#E8EAF6;strokeColor=#1A237E;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="20" y="471" width="1860" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="ds_hdr" value="&lt;b&gt;&lt;font style=&quot;font-size:14px;&quot;&gt;Data&lt;br&gt;Scientist&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Steps 7–10&lt;/font&gt;" style="rounded=1;arcSize=3;fillColor=#1A237E;strokeColor=#0D47A1;strokeWidth=2;fontColor=#FFFFFF;verticalAlign=middle;align=center;html=1;" vertex="1" parent="1">
                    <mxGeometry x="20" y="471" width="155" height="175" as="geometry"/>
                </mxCell>

                <mxCell id="s7" value="&lt;b&gt;7. Model Selection &amp; Architecture&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Task: classification / detection / seg&lt;br&gt;• CNN, ViT, RNN, Transformer, GNN&lt;br&gt;• Pre-trained backbone (ResNet, ViT-L)&lt;br&gt;• Transfer learning vs. train from scratch&lt;br&gt;• Inductive bias matching task&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="195" y="493" width="320" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s8" value="&lt;b&gt;8. Model Training&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Loss function (CE, Focal, IoU, CTC)&lt;br&gt;• Optimiser (SGD, Adam, AdamW)&lt;br&gt;• LR scheduler (cosine, warmup)&lt;br&gt;• Mixed-precision (FP16 / BF16)&lt;br&gt;• Experiment tracking (MLflow, W&amp;B)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="535" y="493" width="320" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s9" value="&lt;b&gt;9. Model Evaluation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Accuracy, Precision, Recall, F1&lt;br&gt;• mAP (detection), mIoU (segmentation)&lt;br&gt;• Confusion matrix analysis&lt;br&gt;• Error analysis per class / slice&lt;br&gt;• Bias &amp; fairness evaluation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="875" y="493" width="320" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s10" value="&lt;b&gt;10. Hyperparameter Tuning&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Grid / random / Bayesian search&lt;br&gt;• LR, batch size, weight decay&lt;br&gt;• Architecture search (NAS)&lt;br&gt;• Optuna, Ray Tune, W&amp;B Sweeps&lt;br&gt;• Cross-validation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="1215" y="493" width="320" height="130" as="geometry"/>
                </mxCell>

                <mxCell id="e78" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d79b00;strokeWidth=2;" edge="1" source="s7" target="s8" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="e89" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;strokeWidth=2;" edge="1" source="s8" target="s9" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="e910" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;strokeWidth=2;" edge="1" source="s9" target="s10" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

                <!-- ════════════════════════════════════════════════════ -->
                <!-- ROW 4 — ML ENGINEER  (Steps 11–15)                   -->
                <!-- ════════════════════════════════════════════════════ -->
                <mxCell id="mle_bg" value="" style="rounded=1;arcSize=3;fillColor=#F3E5F5;strokeColor=#4A148C;strokeWidth=2;" vertex="1" parent="1">
                    <mxGeometry x="20" y="664" width="1860" height="175" as="geometry"/>
                </mxCell>
                <mxCell id="mle_hdr" value="&lt;b&gt;&lt;font style=&quot;font-size:14px;&quot;&gt;ML&lt;br&gt;Engineer&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;Steps 11–15&lt;/font&gt;" style="rounded=1;arcSize=3;fillColor=#4A148C;strokeColor=#38006b;strokeWidth=2;fontColor=#FFFFFF;verticalAlign=middle;align=center;html=1;" vertex="1" parent="1">
                    <mxGeometry x="20" y="664" width="155" height="175" as="geometry"/>
                </mxCell>

                <mxCell id="s11" value="&lt;b&gt;11. Model Compression&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Pruning (structured / unstructured)&lt;br&gt;• Quantisation (INT8, FP16)&lt;br&gt;• Knowledge distillation&lt;br&gt;• TensorRT / ONNX export&lt;br&gt;• FLOP / memory profiling&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="195" y="686" width="295" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s12" value="&lt;b&gt;12. Final Testing &amp; Validation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Hold-out test set evaluation&lt;br&gt;• A/B testing vs. baseline model&lt;br&gt;• Stress testing (OOD / edge cases)&lt;br&gt;• Latency &amp; throughput benchmark&lt;br&gt;• Regression testing&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="505" y="686" width="295" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s13" value="&lt;b&gt;13. CI/CD &amp; MLOps&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Model versioning (DVC, MLflow)&lt;br&gt;• Automated retraining pipelines&lt;br&gt;• Data versioning &amp; lineage&lt;br&gt;• Docker / containerisation&lt;br&gt;• GitHub Actions / Jenkins CI&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="815" y="686" width="295" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s14" value="&lt;b&gt;14. Model Deployment ★&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• REST API (FastAPI, TorchServe)&lt;br&gt;• Cloud: SageMaker / Vertex AI&lt;br&gt;• Edge: ONNX / TFLite / TensorRT&lt;br&gt;• Batch vs. real-time inference&lt;br&gt;• Blue-green / canary deployment&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=3;fontStyle=1;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="1125" y="686" width="295" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s15" value="&lt;b&gt;15. Monitoring &amp; Feedback Loop&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;• Data drift detection (KL divergence)&lt;br&gt;• Model performance tracking&lt;br&gt;• Alerting on accuracy degradation&lt;br&gt;• Human-in-the-loop review&lt;br&gt;• Retraining trigger → back to Step 1&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=8;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
                    <mxGeometry x="1435" y="686" width="295" height="130" as="geometry"/>
                </mxCell>

                <mxCell id="e1112" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;strokeWidth=2;" edge="1" source="s11" target="s12" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="e1213" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#9673a6;strokeWidth=2;" edge="1" source="s12" target="s13" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="e1314" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="s13" target="s14" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="e1415" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;strokeWidth=2;" edge="1" source="s14" target="s15" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

