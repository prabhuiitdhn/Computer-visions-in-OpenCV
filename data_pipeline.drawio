<mxfile host="app.diagrams.net" modified="2026-05-25" agent="GitHub Copilot" version="21.0.0">
    <diagram id="ml-pipeline-roles" name="ML Pipeline by Role — Swimlane">
        <mxGraphModel dx="2114" dy="563" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="&lt;b&gt;&lt;font style=&quot;font-size: 18px;&quot;&gt;Full Machine Learning Pipeline&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Data Acquisition → Model Deployment&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="527" y="20" width="400" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="s1" value="&lt;b&gt;1. Data Acquisition&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Sensors / cameras / APIs&lt;br&gt;• Web scraping / crawling&lt;br&gt;• Public datasets (ImageNet, COCO)&lt;br&gt;• Internal / proprietary data&lt;br&gt;• Simulated / synthetic data&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="100" y="100" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="s2" value="&lt;b&gt;2. Data Annotation / Labelling&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Manual labelling (LabelImg, CVAT)&lt;br&gt;• Crowdsourcing (Amazon Mechanical Turk)&lt;br&gt;• Weak / semi-automatic labelling&lt;br&gt;• Annotation schema definition&lt;br&gt;• Quality review &amp; agreement check (IAA)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="100" y="260" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="s3" value="&lt;b&gt;3. Data Preprocessing&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Resize / normalize / standardize&lt;br&gt;• Denoise, histogram equalization&lt;br&gt;• Handle missing values / outliers&lt;br&gt;• Format conversion (JPEG → TFRecord)&lt;br&gt;• Train / Val / Test split&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="100" y="440" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="s4" value="&lt;b&gt;4. Data Augmentation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Flip, rotate, crop, scale&lt;br&gt;• Colour jitter, brightness, contrast&lt;br&gt;• MixUp, CutOut, CutMix&lt;br&gt;• Mosaic (YOLOv4+)&lt;br&gt;• Generative augmentation (GANs, diffusion)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="100" y="610" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="s5" value="&lt;b&gt;5. Exploratory Data Analysis (EDA)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Class distribution / imbalance check&lt;br&gt;• Feature correlation analysis&lt;br&gt;• Visualise samples per class&lt;br&gt;• Identify data quality issues&lt;br&gt;• Baseline statistics (mean, std, range)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="100" y="780" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="s6" value="&lt;b&gt;6. Feature Engineering&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Hand-crafted: HOG, SIFT, LBP&lt;br&gt;• Deep features: CNN embeddings&lt;br&gt;• Dimensionality reduction: PCA, t-SNE&lt;br&gt;• Feature selection (importance scores)&lt;br&gt;• Embedding lookup (text / categories)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="450" y="780" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="s7" value="&lt;b&gt;7. Model Selection &amp; Architecture&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Task type (classification, detection, seg)&lt;br&gt;• CNN, ViT, RNN, Transformer, GNN&lt;br&gt;• Pre-trained backbone (ResNet, ViT-L)&lt;br&gt;• Transfer learning vs. train from scratch&lt;br&gt;• Inductive bias matching task&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="450" y="610" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="s8" value="&lt;b&gt;8. Model Training&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Loss function (CE, Focal, IoU, CTC)&lt;br&gt;• Optimiser (SGD, Adam, AdamW)&lt;br&gt;• LR scheduler (cosine, warmup)&lt;br&gt;• Mixed-precision (FP16 / BF16)&lt;br&gt;• Distributed training (DDP, FSDP)&lt;br&gt;• Experiment tracking (MLflow, W&amp;B)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="450" y="440" width="260" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="s9" value="&lt;b&gt;9. Model Evaluation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Accuracy, Precision, Recall, F1&lt;br&gt;• mAP (detection), mIoU (segmentation)&lt;br&gt;• Confusion matrix analysis&lt;br&gt;• Error analysis per class/slice&lt;br&gt;• Bias &amp; fairness evaluation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="450" y="260" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="s10" value="&lt;b&gt;10. Hyperparameter Tuning&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Grid / random / Bayesian search&lt;br&gt;• Learning rate, batch size, weight decay&lt;br&gt;• Architecture search (NAS)&lt;br&gt;• Optuna, Ray Tune, W&amp;B Sweeps&lt;br&gt;• Cross-validation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="450" y="100" width="260" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="s11" value="&lt;b&gt;11. Model Compression &amp; Optimisation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Pruning (unstructured / structured)&lt;br&gt;• Quantisation (INT8, FP16)&lt;br&gt;• Knowledge distillation&lt;br&gt;• TensorRT / ONNX export&lt;br&gt;• FLOP / memory profiling&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="800" y="100" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="s12" value="&lt;b&gt;12. Final Testing &amp; Validation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Hold-out test set evaluation&lt;br&gt;• A/B testing vs. baseline/previous model&lt;br&gt;• Stress testing (edge cases, OOD)&lt;br&gt;• Latency &amp; throughput benchmarking&lt;br&gt;• Regression testing (no degradation)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="800" y="270" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="s13" value="&lt;b&gt;13. CI/CD &amp; MLOps&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Model versioning (DVC, MLflow)&lt;br&gt;• Automated retraining pipelines&lt;br&gt;• Data versioning &amp; lineage&lt;br&gt;• Docker / containerisation&lt;br&gt;• GitHub Actions / Jenkins CI&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="800" y="440" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="s14" value="&lt;b&gt;14. Model Deployment&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• REST API (FastAPI, Flask, TorchServe)&lt;br&gt;• Cloud: AWS SageMaker / GCP Vertex AI&lt;br&gt;• Edge: ONNX Runtime / TFLite / TensorRT&lt;br&gt;• Batch vs. real-time inference&lt;br&gt;• Blue-green / canary deployment&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;arcSize=10;align=left;spacingLeft=8;strokeWidth=3;" parent="1" vertex="1">
                    <mxGeometry x="800" y="610" width="260" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="s15" value="&lt;b&gt;15. Monitoring &amp; Feedback Loop&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;• Data drift detection (KL divergence)&lt;br&gt;• Model performance tracking over time&lt;br&gt;• Alerting on accuracy degradation&lt;br&gt;• Human-in-the-loop review&lt;br&gt;• Retraining trigger → back to Step 1&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=0;arcSize=10;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="800" y="780" width="260" height="120" as="geometry"/>
                </mxCell>
